ENVIRONMENT=development
DJANGO_SECRET_KEY=replace-with-any-random-local-dev-secret

# Required for Google OAuth login
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# If testing production-style Postgres locally, set DATABASE_URL.
# Leave unset for the default local SQLite setup.
# DATABASE_URL=postgres://username:password@localhost:5432/project_a_17
