# .gitignore generated by Google Gemini 3 Pro and edited by @notvoyager7 (Kenning) to exclude
# all files (related to configs and local development) that should not be hosted on the GitHub

# --- Python Core ---
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# --- Virtual Environments ---
# Virtualenv/vism/pyenv directories (common names)
venv/
env/
.venv/
.env/
venv.bak/

# --- Django Specific ---
# Local development database
db.sqlite3
db.sqlite3-journal

# Log files
*.log

# Static files collected by 'python manage.py collectstatic'
staticfiles/

# User-uploaded Media
media/

# --- Security / Configuration ---
.env
.env.local
local_settings.py

# --- IDEs & Editors ---
# JetBrains (PyCharm) - Project specific settings that shouldn't be shared
.idea/

# VS Code - User specific settings
.vscode/

# --- Operating System Files ---
# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Heroku ---
# Ignore accidentally created Procfile for locally testing with non-standard names
.heroku/